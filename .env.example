# Copy this file to ".env" and fill in your real values.

# Your Anthropic API key (https://console.anthropic.com/ -> API Keys)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# The exact title of the Google Sheet that acts as the database/API.
# The Sheet must be shared with your service account email (see README).
GOOGLE_SHEET_NAME=AI Timesheet DB

# (Optional) Path to the Git repository to analyze.
# Leave unset/"." to analyze the folder you launch the app from, or point it
# at any repo, e.g. GIT_REPO_PATH=C:\Users\you\work\my-project
GIT_REPO_PATH=.
